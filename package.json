{
  "name": "bethel-church",
  "version": "1.0.0",
  "description": "Bethel Mrgashat Bible Desktop Application",
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -k \"npm run start:angular\" \"npm run start:electron\"",
    "start:angular": "ng serve --port 4200",
    "start:electron": "wait-on http://localhost:4200 && npm run build:electron && electron .",
    "preview": "npm run build:angular && npm run build:electron && NODE_ENV=production electron .",
    "build": "npm run build:angular && npm run build:electron",
    "build:angular": "ng build --configuration production",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:electron:dev": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "build:web": "ng build --configuration web",
    "preview:web": "npm run build:web && npx serve dist/web/browser",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3 --arch arm64"
  },
  "keywords": [],
  "author": "Bethel Church",
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.1.8",
    "primeflex": "^3.3.1",
    "primeicons": "^6.0.1",
    "primeng": "^17.18.0",
    "rxjs": "~7.8.0",
    "sql.js": "^1.14.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.30",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "typescript": "~5.4.2",
    "wait-on": "^7.2.0"
  }
}
